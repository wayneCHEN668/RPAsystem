# AI 模型
DASHSCOPE_API_KEY=sk-0a9ece71d4984aa7a9dab3f523fd470e
DASHSCOPE_BASE_URL=
ANALYZER_MODEL=qwen-vl-plus

# 并发分析帧数（受 API Rate Limit 影响，建议 1~5）
ANALYZER_CONCURRENCY=3

# 目标系统
BASE_URL=localhost:8085
SYS_USERNAME=admin
SYS_PASSWORD=password123

# ── pipeline 调参 ────────────────────────────
# SSIM 相似度阈值（0~1）
# 越高 = 越严格 = 抽更多帧；推荐 0.88~0.95
# 0.92 适合普通表单操作；0.95 适合快速点击场景
SIMILARITY_THRESHOLD=0.92
# 抽帧采样间隔（秒）：过滤动画过渡帧，降低噪声
SAMPLE_INTERVAL_SEC=0.2

# 数据库（可选）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=business_db
DB_USER=
DB_PASS=

# 执行配置
HEADLESS=false
SLOW_MO=50
SCREENSHOT_ON_FAIL=true
OUTPUT_DIR=./scripts
FRAMES_DIR=./frames