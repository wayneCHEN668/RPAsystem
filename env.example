# ══════════════════════════════════════════════
# RPAsystem 环境变量配置
# 复制本文件为 .env，填写实际值后使用
# .env 已加入 .gitignore，不会提交到版本库
# ══════════════════════════════════════════════

# ── AI 模型 ─────────────────────────────────
# DashScope API Key（必填，阿里云百炼平台）
# 获取地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# DashScope 自定义端点（可选，默认自动选择区域）
# 国内：https://dashscope.aliyuncs.com/api/v1
# 新加坡：https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_BASE_URL=

# 分析帧使用的模型（默认 qwen-vl-max-latest，推荐）
# 备选：qwen-vl-plus / qwen-vl-max
ANALYZER_MODEL=qwen-vl-max-latest

# 并发分析帧数（受 API Rate Limit 影响，建议 1~5）
ANALYZER_CONCURRENCY=3

# ── 目标系统 ─────────────────────────────────
# 被自动化的系统入口 URL
BASE_URL=https://your-system.com

# 系统账号（生成的脚本会引用 process.env，这里仅供本地运行参考）
SYS_USERNAME=admin
SYS_PASSWORD=

# ── pipeline 调参 ────────────────────────────
# SSIM 相似度阈值（0~1）
# 越高 = 越严格 = 抽更多帧；推荐 0.88~0.95
# 0.92 适合普通表单操作；0.95 适合快速点击场景
SIMILARITY_THRESHOLD=0.92

# 抽帧采样间隔（秒）：过滤动画过渡帧，降低噪声
SAMPLE_INTERVAL_SEC=0.2

# ── 输出路径 ─────────────────────────────────
# 生成脚本的默认目录（generate 命令未指定 --output 时使用）
OUTPUT_DIR=./scripts

# 临时帧文件目录（处理完成后自动清除，除非使用 --keep-frames）
FRAMES_DIR=./frames

# ── 执行配置（engine 模块用，pipeline 不需要）────
HEADLESS=false
SLOW_MO=50
SCREENSHOT_ON_FAIL=true
